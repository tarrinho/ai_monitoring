# AI-Monitoring configuration — copy to .env and fill in.
# .env is git-ignored. NEVER commit real keys.

# --- listen / storage --------------------------------------------------------
MONITOR_HOST=0.0.0.0
MONITOR_PORT=9925
MONITOR_DB_PATH=/data/ai-monitoring.db

# --- sampling ----------------------------------------------------------------
MONITOR_SAMPLE_INTERVAL=5
MONITOR_RETENTION_SAMPLES=8640
MONITOR_DB_RETENTION_HOURS=720
MONITOR_HTTP_TIMEOUT=4
# Max bytes read from a single collector response (defends against a compromised
# or MITM'd backend returning a huge body and OOM-ing the monitor). Default 16 MiB.
MONITOR_HTTP_MAX_BYTES=16777216
# 1 = log each collector's availability + error to `docker logs` (why a panel is
# missing, e.g. GPU). Logs on startup + on change.
MONITOR_DEBUG=0

# --- optional dashboard auth (Bearer token / ?token=). Empty = open. ---------
# Use ≥16 random chars (a short token is flagged at boot). Rate-limited: after
# AUTH_MAX_FAILS bad tokens from one IP within AUTH_WINDOW_S, that IP is locked
# (429) for AUTH_LOCKOUT_S. Behind a reverse proxy set AUTH_TRUSTED_PROXY=1 so the
# real client IP is read from X-Forwarded-For — the proxy must APPEND (not replace)
# it, since the collector trusts the rightmost hop (F4).
MONITOR_DASHBOARD_TOKEN=
MONITOR_AUTH_MAX_FAILS=10
MONITOR_AUTH_WINDOW_S=300
MONITOR_AUTH_LOCKOUT_S=900
MONITOR_AUTH_TRUSTED_PROXY=0
# F2: with no token the whole dashboard + API is open — refused at boot unless you
# opt in here (loopback / behind an authenticating proxy only).
MONITOR_ALLOW_OPEN=0
# F3: the session cookie carries the token, so it is marked Secure (HTTPS-only) by
# default. Set to 1 ONLY for local plain-HTTP testing.
MONITOR_COOKIE_ALLOW_INSECURE=0

# --- multi-user access (username + password login; SQLite-backed) -------------
# External users log in with their own credentials instead of sharing the token.
# The FIRST admin is seeded from these on an empty users table (idempotent — once
# any user exists these are ignored). After first boot, manage users at
# /admin/users. Roles: 'admin' (manage users) or 'viewer' (read-only).
MONITOR_ADMIN_USER=
MONITOR_ADMIN_PASSWORD=
MONITOR_ADMIN_EMAIL=
# How long a login session lasts before re-auth (seconds; default 7 days).
MONITOR_SESSION_TTL_S=604800
# Hard ceiling on concurrent server-side sessions (bounds in-memory session
# stores; oldest-expiring are evicted past this). Default 2000.
MONITOR_SESSION_MAX=2000
# How long the access/admin audit trail is kept (days). Admins review it in the
# Activity log section of /admin/users.
MONITOR_AUDIT_RETENTION_DAYS=90

# --- LiteLLM (JSON only, no prometheus) --------------------------------------
LITELLM_BASE_URL=http://CHANGE_ME:4000
LITELLM_MASTER_KEY=sk-CHANGE_ME
LITELLM_SPEND_WINDOW_MIN=15
SLO_LATENCY_MS=2000
# Heavy calls (/health probes every deployment, /spend/logs pulls the whole day)
# poll on this slower cadence instead of every sample — protects a busy proxy.
LITELLM_HEAVY_INTERVAL=60
# Busy-proxy escape hatches: set to 0 to stop the heavy call entirely.
#   SPEND=0  -> no /spend/logs pull (drops latency/cost/key panels; keeps backlog)
#   HEALTH=0 -> no /health per-deployment probing
LITELLM_SPEND_ENABLED=1
# How to gather spend/usage:
#   full = raw /spend/logs (whole-day pull; gives latency percentiles but heavy —
#          can peg a CPU core on a busy proxy)
#   lite = server-side aggregates (/global/activity, /global/spend/keys): tiny
#          payloads, ~0 CPU, no freeze. Gives requests/tokens/cost/per-model/
#          top-keys but NO latency. RECOMMENDED for a busy proxy.
LITELLM_SPEND_MODE=full
# Adaptive load-shedding: when host 1-min load PER CORE reaches this, the monitor
# auto-STOPS the heavy calls (/health probe + full /spend/logs) and resumes when
# load drops. 0 = off. ~4 = "load is 4x the cores" (saturated). Cheap calls
# (backlog, liveliness, models, lite aggregates) keep running.
LITELLM_LOAD_SHED=0
# Hard cap on /spend/logs rows parsed per poll (most-recent kept). Bounds CPU on
# a proxy that accumulates a huge day of logs.
LITELLM_SPEND_MAX_ROWS=20000
# Timeout for the heavy calls (/health, /spend/logs). The default 4s is too short
# for a busy proxy's whole-day /spend/logs query — too low and it always times
# out and the latency/cost/key panels stay blank.
LITELLM_SPEND_TIMEOUT=20
# Circuit breaker: after this many consecutive heavy-call failures, stop calling
# for the cooldown (seconds), then probe once. Prevents the monitor from
# hammering — and freezing — a struggling proxy. Auto-recovers on success.
LITELLM_CB_THRESHOLD=3
LITELLM_CB_COOLDOWN=300
# Refuse a /spend/logs response bigger than this (bytes) before deserializing it.
LITELLM_SPEND_MAX_BYTES=67108864
# Set to 1 for verbose per-call LiteLLM logging in `docker logs` (diagnostics).
LITELLM_DEBUG=0

# --- Ollama ------------------------------------------------------------------
OLLAMA_BASE_URL=http://CHANGE_ME:11434

# --- llama.cpp server --------------------------------------------------------
LLAMACPP_BASE_URL=http://CHANGE_ME:8080
LLAMACPP_API_KEY=

# Container liveness + alive-time (Docker API). Requires the Docker socket mounted
# + group_add in docker-compose.yml. EMPTY = show ALL host containers (auto-
# discover). Set a comma-separated list to watch only specific ones.
MONITOR_CONTAINERS=
# e.g. MONITOR_CONTAINERS=llama-cpp-server,new_open-webui,new_litellm,new_caddy,new_ollama
# F1 (recommended): reach Docker through a read-only socket proxy over TCP instead
# of mounting the host-root socket. docker-compose.yml ships a docker-socket-proxy
# service; point this at it. When set, the raw socket is NOT mounted into the
# monitor, so a monitor compromise can't reach the full host-root Docker API.
MONITOR_DOCKER_API_URL=http://docker-socket-proxy:2375
# Legacy direct-socket fallback (used only when MONITOR_DOCKER_API_URL is empty).
MONITOR_DOCKER_SOCKET=/var/run/docker.sock
# GID of the host 'docker' group, so the non-root monitor can read the socket.
# Find it on the host with:  getent group docker | cut -d: -f3
DOCKER_GID=999

# --- GPU (pick ONE mode; leave all empty to try a local GPU CLI) -------------
# Mode 0 (SAFEST — LOCAL host GPU): the host writes nvidia-smi CSV to a file on a
#   timer (see deploy/gpu-metrics.service) and the monitor reads it, bind-mounted
#   READ-ONLY. No SSH, no network, no shell into the host. Best when the GPU is on
#   the SAME host as this container (Alpine can't run a passed-through nvidia-smi).
GPU_METRICS_FILE=
# GPU_METRICS_FILE=/gpu/gpu.csv          # mount host dir read-only: - /var/lib/aimon-gpu:/gpu:ro
GPU_FILE_MAX_AGE=60
# Mode 1 (agentless SSH): monitor runs nvidia-smi on the remote GPU host.
#   Mount the key into the container and point GPU_SSH_KEY at it.
GPU_SSH=
# GPU_SSH=user@gpuhost
GPU_SSH_PORT=22
GPU_SSH_KEY=
# GPU_SSH_KEY=/keys/gpu_id_ed25519
# Mode 2 (HTTP agent): a small endpoint on the GPU box returning GPU JSON.
GPU_METRICS_URL=
# GPU_METRICS_URL=http://gpuhost:9835/gpu

# --- alert thresholds (0 disables each) --------------------------------------
ALERT_CPU_PCT=0
ALERT_MEM_PCT=0
ALERT_DISK_PCT=0
ALERT_GPU_PCT=0
ALERT_VRAM_PCT=0
ALERT_LLM_WAIT_MS=0
ALERT_BACKLOG=0
ALERT_ON_BACKEND_DOWN=1
ALERT_REPEAT_MIN=30

# --- per-key anomaly / abuse detection (0 disables) --------------------------
ANOMALY_FACTOR=4
ANOMALY_MIN_REQS=20
ANOMALY_KEY_BUDGET_HR=0

# --- alert channel (webhook) -------------------------------------------------
# Operator-set global webhook (trusted, not SSRF-checked). Fires alongside any
# per-user webhooks. Each user can also set their OWN webhook at /account.
ALERT_WEBHOOK_URL=
# Per-user webhooks are user-supplied → SSRF-guarded (private/loopback/metadata
# addresses refused). Relax/tighten:
MONITOR_WEBHOOK_ALLOW_PRIVATE=0
MONITOR_WEBHOOK_HTTPS_ONLY=0
# Optional host allowlist for user webhooks (empty = any public host):
MONITOR_WEBHOOK_ALLOW_HOSTS=
# Max per-user webhooks resolved + posted per alert tick (fan-out is also
# concurrent + time-boxed, so one slow host can't stall the sampling loop).
MONITOR_WEBHOOK_MAX_RECIPIENTS=50

# --- retention rollups -------------------------------------------------------
ROLLUP_RAW_HOURS=24
ROLLUP_MIN_DAYS=30
ROLLUP_HOUR_DAYS=365
